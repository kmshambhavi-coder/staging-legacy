n_status\":\"Provisioned\",\"mac_address\":\"XXXXXXXXXXXXXXXXX\",\"bios_version\":\"1.6.5\",\"agent_load_flags\":\"0\",\"status\":\"normal\",\"bios_manufacturer\":\"Dell Inc.\",\"machine_domain\":\"SIEMPLIFY.LOCAL\",\"device_policies\":{\"sensor_update\":{\"applied\":true,\"applied_date\":\"2019-05-05T12:52:23.121596885Z\",\"settings_hash\":\"XXXXXXXXXXXXXXXXXXXXX\",\"policy_type\":\"sensor-update\",\"assigned_date\":\"2019-05-05T12:51:37.544605747Z\",\"policy_id\":\"XXXXXXXXXXXXXXXXXXXXXXXX\"},\"remote_response\":{\"applied\":true,\"applied_date\":\"2019-02-10T07:57:59.064362539Z\",\"settings_hash\":\"XXXXXXXX\",\"policy_type\":\"remote-response\",\"assigned_date\":\"2019-02-10T07:57:50.610924385Z\",\"policy_id\":\"XXXXXXXXXXXXXXXXXXXXXXXXXXXXX\"},\"device_control\":{\"applied\":true,\"applied_date\":\"2019-03-25T15:01:28.51681072Z\",\"assigned_date\":\"2019-03-25T15:00:22.442519168Z\",\"policy_type\":\"device-control\",\"policy_id\":\"XXXXXXXXXXXXXXXXXXXXXX\"},\"prevention\":{\"applied\":true,\"applied_date\":\"2019-04-04T06:54:06.909774295Z\",\"settings_hash\":\"XXXXXXXXXXXXXXXXXXXXXX\",\"policy_type\":\"prevention\",\"assigned_date\":\"2019-04-04T06:53:57.135897343Z\",\"policy_id\":\"XXXXXXXXXXXXXXXXXXXXXXXXXX\"},\"global_config\":{\"applied\":true,\"applied_date\":\"2019-02-10T07:57:53.70275875Z\",\"settings_hash\":\"XXXXXXXXXXXXXXXXXXXXXXXXX\",\"policy_type\":\"globalconfig\",\"assigned_date\":\"2019-02-10T07:57:50.610917888Z\",\"policy_id\":\"XXXXXXXXXXXXXXXXXXXXXXX\"}},\"cid\":\"XXXXXXXXXXXXXXXXXXXXXXXXXXXXx\",\"agent_local_time\":\"2019-05-05T15:52:08.172Z\",\"slow_changing_modified_timestamp\":\"2019-05-12T12:37:35Z\",\"service_pack_major\":\"0\",\"device_id\":\"XXXXXXXXXXXXXXXXXXXXX\",\"system_product_name\":\"Latitude XXXX\",\"product_type\":\"1\",\"local_ip\":\"1.1.1.1\",\"external_ip\":\"1.1.1.1\",\"major_version\":\"10\",\"platform_id\":\"0\",\"config_id_base\":\"XXXXXXXXXXXXXXXXXXX\",\"policies\":[{\"applied\":true,\"applied_date\":\"2019-04-04T06:54:06.909774295Z\",\"settings_hash\":\"XXXXXXXXXXXXXXXXXXXXXX\",\"policy_type\":\"prevention\",\"assigned_date\":\"2019-04-04T06:53:57.135897343Z\",\"policy_id\":\"XXXXXXXXXXXXXXXXXXXXXXXXXX\"}],\"agent_version\":\"4.26.XXXX.0\",\"pointer_size\":\"8\",\"last_seen\":\"2019-05-13T07:21:30Z\"}]","ShowResult":true}],"Creator":"admin","IsEnabled":true,"IsCustom":true,"AiGenerated":false,"IsSystem":false,"Version":1.0,"TimeoutSeconds":600,"IsAsync":null,"AsyncPollingIntervalInSeconds":300,"TotalIntervalTimeoutForAsyncInSeconds":3600,"Parameters":[{"CustomActionId":0,"IsMandatory":false,"DefaultValue":"","Description":"Specify the ID of the customer for which you want to execute the action.","Name":"Customer ID","Value":"","Type":0,"OptionalValues":null,"OptionalValuesJson":null},{"CustomActionId":0,"IsMandatory":false,"DefaultValue":"Equal","Description":"Specify what logic should be used, when searching for hosts.","Name":"Filter Logic","Value":"Equal","Type":15,"OptionalValues":["Equal","Contains"],"OptionalValuesJson":"[\"Equal\",\"Contains\"]"},{"CustomActionId":0,"IsMandatory":false,"DefaultValue":"","Description":"Specify the value that should be used to filter hosts.","Name":"Filter Value","Value":"","Type":0,"OptionalValues":null,"OptionalValuesJson":null},{"CustomActionId":0,"IsMandatory":false,"DefaultValue":"50","Description":"Specify how many hosts to return. Default: 50. Maximum: 1000.","Name":"Max Hosts To Return","Value":"50","Type":0,"OptionalValues":null,"OptionalValuesJson":null}],"DefaultResultValue":null,"PythonVersion":"None","ActionType":1,"SimulationData":{"Entities":[]},"SimulationDataJson":"{\"Entities\": []}","AICategories":[],"OutcomeCategories":[],"AIDescription":"Lists available hosts in CrowdStrike Falcon based on specific search criteria. This action allows users to query the CrowdStrike environment for devices using hostname filters and retrieve detailed information about them, including IP addresses, OS versions, and agent status.\n\n### Parameters\n| Parameter | Type | Mandatory | Description |\n| :--- | :--- | :--- | :--- |\n| Customer ID | String | No | Specify the ID of the customer (CID) for which you want to execute the action. If not provided, the default CID from the integration configuration is used. |\n| Filter Logic | String | No | Determines the matching logic for the search. Options are 'Equal' (exact match) or 'Contains' (partial match). Default is 'Equal'. |\n| Filter Value | String | No | The hostname or partial hostname string used to filter the hosts. |\n| Max Hosts To Return | Integer | No | The maximum number of host records to retrieve. Supports values between 1 and 1000. Default is 50. |\n\n### Flow Description\n1. **Parameter Extraction:** Retrieves the API credentials, Customer ID, and search parameters (Filter Value, Logic, and Limit).\n2. **Validation:** Validates that the 'Max Hosts To Return' is within the allowed range (1-1000).\n3. **Host Discovery:** Calls the CrowdStrike API to find device IDs that match the provided hostname filter.\n4. **Detail Retrieval:** Fetches full metadata for the identified device IDs, including network details and system information.\n5. **Local Filtering:** If 'Contains' logic is selected, the action performs additional client-side filtering to ensure results match the partial string.\n6. **Output Generation:** Populates a data table named 'Hosts' with the results and attaches the raw JSON data to the action output.","AiShortDescription":null,"ParametersDescription":null,"EntityTypes":[]}