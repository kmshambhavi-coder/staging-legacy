\"bash\",\"filepath\":\"/usr/bin/bash\",\"local_process_id\":\"16943\",\"md5\":\"xx\",\"process_graph_id\":\"cc\",\"process_id\":\"cc\",\"sha256\":\"cc\",\"timestamp\":\"2025-09-19T06:39:47Z\",\"user_graph_id\":\"cc\",\"user_name\":\"root\"},\"parent_process_id\":\"cc\",\"pattern_disposition\":0,\"pattern_disposition_description\":\"ccc\",\"pattern_disposition_details\":{\"blocking_unsupported_or_disabled\":false,\"bootup_safeguard_enabled\":false,\"containment_file_system\":false,\"critical_process_disabled\":false,\"detect\":false,\"fs_operation_blocked\":false,\"handle_operation_downgraded\":false,\"inddet_mask\":false,\"indicator\":false,\"kill_action_failed\":false,\"kill_parent\":false,\"kill_process\":false,\"kill_subprocess\":false,\"mfa_required\":false,\"operation_blocked\":false,\"policy_disabled\":false,\"prevention_provisioning_enabled\":false,\"process_blocked\":false,\"quarantine_file\":false,\"quarantine_machine\":false,\"registry_operation_blocked\":false,\"response_action_already_applied\":false,\"response_action_failed\":false,\"response_action_triggered\":false,\"rooting\":false,\"sensor_only\":false,\"suspend_parent\":false,\"suspend_process\":false},\"pattern_id\":10306,\"platform\":\"Linux\",\"poly_id\":\"ccc\",\"priority_explanation\":[\"[MOD]Theseverityofthedetection\"],\"priority_value\":40,\"process_end_time\":\"1758263941\",\"process_id\":\"cc\",\"process_start_time\":\"1758263941\",\"product\":\"epp\",\"scenario\":\"suspicious_activity\",\"seconds_to_resolved\":0,\"seconds_to_triaged\":0,\"severity\":30,\"severity_name\":\"Low\",\"sha1\":\"cc\",\"sha256\":\"xx\",\"show_in_ui\":true,\"source_products\":[\"FalconInsight\"],\"source_vendors\":[\"CrowdStrike\"],\"status\":\"new\",\"tactic\":\"cc\",\"tactic_id\":\"CSTA0006\",\"technique\":\"MaliciousActivity\",\"technique_id\":\"CST0002\",\"template_instance_id\":\"1357\",\"timestamp\":\"2025-09-19T06:39:01.842Z\",\"tree_id\":\"cc\",\"tree_root\":\"\",\"triggering_process_graph_id\":\"ccc\",\"type\":\"ldt\",\"updated_timestamp\":\"2025-09-19T07:39:03.206700216Z\",\"user_name\":\"root\"}","ShowResult":true}],"Creator":"admin","IsEnabled":true,"IsCustom":true,"AiGenerated":false,"IsSystem":false,"Version":1.0,"TimeoutSeconds":600,"IsAsync":null,"AsyncPollingIntervalInSeconds":300,"TotalIntervalTimeoutForAsyncInSeconds":3600,"Parameters":[{"CustomActionId":0,"IsMandatory":true,"DefaultValue":"","Description":"Specify the ID of the alert.","Name":"Alert ID","Value":"","Type":0,"OptionalValues":null,"OptionalValuesJson":null}],"DefaultResultValue":null,"PythonVersion":"None","ActionType":1,"SimulationData":{"Entities":null},"SimulationDataJson":null,"AICategories":["Enrichment"],"OutcomeCategories":[],"AIDescription":"### General Description\nThe **Get Alert Details** action retrieves comprehensive metadata and status information for a specific alert within the CrowdStrike Falcon platform. It is primarily used to gather deep context about a detection, including device information, behavior details, and MITRE ATT&CK mappings, which can then be used for automated decision-making or reporting within a playbook.\n\n### Parameters Description\n| Parameter | Type | Mandatory | Description |\n| :--- | :--- | :--- | :--- |\n| **Alert ID** | String | Yes | The unique identifier (Composite ID) of the alert in CrowdStrike Falcon for which you want to retrieve details. |\n\n### Additional Notes\n- This action does not require entities to be present in the Google SecOps case; it operates solely based on the provided **Alert ID** parameter.\n- If the specified Alert ID is not found, the action will fail with an informative error message.\n\n### Flow Description\n1. **Authentication**: The action establishes a secure connection to the CrowdStrike Falcon API using the configured Client ID and Secret.\n2. **Data Retrieval**: It sends a request to the CrowdStrike Alerts API (`/alerts/entities/alerts/v2`) specifically for the provided Alert ID.\n3. **Validation**: The action checks if the API returned valid data for the requested ID.\n4. **Output**: Upon success, the full raw JSON data of the alert is returned as the action's result, and a success message is logged.","AiShortDescription":null,"ParametersDescription":null,"EntityTypes":[]}