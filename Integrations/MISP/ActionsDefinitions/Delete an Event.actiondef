{"Name":"Delete an Event","Description":"Delete event in MISP","Script":"# Copyright 2026 Google LLC\n#\n# Licensed under the Apache License, Version 2.0 (the \"License\");\n# you may not use this file except in compliance with the License.\n# You may obtain a copy of the License at\n#\n#     http://www.apache.org/licenses/LICENSE-2.0\n#\n# Unless required by applicable law or agreed to in writing, software\n# distributed under the License is distributed on an \"AS IS\" BASIS,\n# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n# See the License for the specific language governing permissions and\n# limitations under the License.\n\nfrom __future__ import annotations\nfrom SiemplifyUtils import output_handler\nfrom SiemplifyAction import SiemplifyAction\nfrom ScriptResult import EXECUTION_STATE_COMPLETED, EXECUTION_STATE_FAILED\nfrom MISPManager import MISPManager\nfrom TIPCommon.extraction import extract_action_param, extract_configuration_param\nfrom exceptions import MISPManagerEventIdNotFoundError, MISPManagerError\nfrom constants import INTEGRATION_NAME, DELETE_EVENT_SCRIPT_NAME\n\n\n@output_handler\ndef main():\n    siemplify = SiemplifyAction()\n    siemplify.script_name = DELETE_EVENT_SCRIPT_NAME\n\n    siemplify.LOGGER.info(\"----------------- Main - Param Init -----------------\")\n\n    # INIT INTEGRATION CONFIGURATION:\n    api_root = extract_configuration_param(\n        siemplify, provider_name=INTEGRATION_NAME, param_name=\"Api Root\"\n    )\n    api_token = extract_configuration_param(\n        siemplify, provider_name=INTEGRATION_NAME, param_name=\"Api Key\"\n    )\n    use_ssl = extract_configuration_param(\n        siemplify,\n        provider_name=INTEGRATION_NAME,\n        param_name=\"Use SSL\",\n        default_value=False,\n        input_type=bool,\n    )\n    ca_certificate = extract_configuration_param(\n        siemplify,\n        provider_name=INTEGRATION_NAME,\n        param_name=\"CA Certificate File - parsed into Base64 String\",\n    )\n    siemplify.LOGGER.info(\"----------------- Main - Started -----------------\")\n\n    # INIT ACTION PARAMETERS:\n    event_id = extract_action_param(\n        siemplify, param_name=\"Event ID\", is_mandatory=True, print_value=True\n    )\n    id_type = \"ID\" if event_id.isdigit() else \"UUID\"\n\n    status = EXECUTION_STATE_COMPLETED\n    result_value = True\n\n    try:\n        manager = MISPManager(api_root, api_token, use_ssl, ca_certificate)\n\n        manager.get_event_by_id_or_raise(event_id)\n\n        try:\n            api_message = manager.delete_event(event_id)\n            output_message = f\"Successfully deleted event with {id_type} {event_id} in {INTEGRATION_NAME}\"\n            siemplify.result.add_result_json(api_message.to_json())\n        except MISPManagerError as e:\n            if isinstance(e, MISPManagerEventIdNotFoundError):\n                raise\n            output_message = f\"Action wasn’t able to delete event with {id_type} {event_id} in {INTEGRATION_NAME}\"\n\n    except Exception as e:\n        output_message = (\n            f\"Error executing action '{DELETE_EVENT_SCRIPT_NAME}'. Reason: \"\n        )\n        output_message += (\n            f\"Event with {id_type} {event_id} was not found in {INTEGRATION_NAME}\"\n            if isinstance(e, MISPManagerEventIdNotFoundError)\n            else str(e)\n        )\n        siemplify.LOGGER.error(output_message)\n        siemplify.LOGGER.exception(e)\n        status = EXECUTION_STATE_FAILED\n        result_value = False\n\n    siemplify.LOGGER.info(\"----------------- Main - Finished -----------------\")\n    siemplify.LOGGER.info(\n        f\"\\n  status: {status}\\n  result_value: {result_value}\\n  output_message: {output_message}\"\n    )\n    siemplify.end(output_message, result_value, status)\n\n\nif __name__ == \"__main__\":\n    main()\n","IntegrationIdentifier":"MISP","ScriptResultName":"is_success","DynamicResultsMetadata":[{"ResultName":"JsonResult","ResultExample":"[{\"name\": \"Event deleted.\", \"message\": \"Event deleted.\", \"url\": \"/events/delete/4\"}]","ShowResult":true}],"Creator":"admin","IsEnabled":true,"IsCustom":true,"AiGenerated":false,"IsSystem":false,"Version":0.0,"TimeoutSeconds":600,"IsAsync":false,"AsyncPollingIntervalInSeconds":300,"TotalIntervalTimeoutForAsyncInSeconds":3600,"Parameters":[{"CustomActionId":0,"IsMandatory":true,"DefaultValue":"","Description":"Specify the ID or UUID of the event that you want to delete.","Name":"Event ID","Value":"","Type":0,"OptionalValues":null,"OptionalValuesJson":null}],"DefaultResultValue":null,"PythonVersion":"None","ActionType":1,"SimulationData":{"Entities":null},"SimulationDataJson":null,"AICategories":[],"OutcomeCategories":[],"AIDescription":"### General Description\nDeletes a specific event from the MISP (Malware Information Sharing Platform) instance. This action allows users to remove events by providing either a numeric ID or a UUID. It is useful for cleaning up false positives, redundant data, or incorrectly created events within the threat intelligence platform.\n\n### Parameters Description\n\n| Parameter | Type | Mandatory | Description |\n| :--- | :--- | :--- | :--- |\n| Event ID | String | Yes | The unique identifier of the event to delete. This can be either the numeric ID (e.g., '4') or the UUID string. |\n\n### Additional Notes\n- The action first verifies the existence of the event before attempting deletion. If the event is not found, the action will fail with a specific 'not found' error.\n- This action performs a permanent deletion in the external MISP system.\n\n### Flow Description\n1. **Setup**: The action initializes the MISP manager using the provided API root, API key, and SSL configuration.\n2. **Parameter Extraction**: It retrieves the `Event ID` from the action parameters and determines if it is a numeric ID or a UUID.\n3. **Verification**: It calls the MISP API to verify that the event exists. If the event does not exist, an exception is raised, and the action fails.\n4. **Execution**: If verified, it sends a POST request to the MISP deletion endpoint for the specified event.\n5. **Result Handling**: The action captures the API response message, adds it to the result JSON, and completes with a success message.","AiShortDescription":null,"ParametersDescription":null,"EntityTypes":[]}